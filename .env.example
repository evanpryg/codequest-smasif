# === Frontend (Vite) — aman diekspos ke browser ===
# Nilai diambil dari Dashboard Supabase: Project Settings > API
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# === Edge Function: student-login — RAHASIA, jangan diekspos ke browser ===
# SUPABASE_URL & SUPABASE_SERVICE_ROLE_KEY disuntik otomatis di runtime cloud.
# Satu secret harus di-set manual di Dashboard > Edge Functions > Secrets:
#   JWT_SECRET = nilai "JWT Secret" project (Project Settings > API)
# Dipakai untuk menandatangani token sesi siswa (HS256). JANGAN taruh di file
# .env frontend dan jangan pernah dibagikan/di-commit.
